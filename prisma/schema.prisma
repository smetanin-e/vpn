model DailyChargeLog {
    id   Int      @id @default(autoincrement())
    date DateTime @unique

    totalClients    Int @default(0)
    successfulCount Int @default(0)
    failedCount     Int @default(0)

    totalAmount Int @default(0)

    disabledPeers Json?
    failedDetails Json?

    status ChargeStatus @default(PENDING)
    error  String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("daily_charge_logs")
}

//Модель для учета трафика по месяцам
//TODO Отсутствует - (сделать в будущем)
model PeerMonthlyStats {
    id    Int      @id @default(autoincrement())
    month DateTime

    peerId Int
    peer   Peer @relation(fields: [peerId], references: [id])

    receivedBytes BigInt
    sentBytes     BigInt

    createdAt DateTime @default(now())
}

enum PeerStatus {
    ACTIVE
    INACTIVE
}

enum TransactionType {
    TOP_UP
    DAILY_CHARGE
}

enum ServerType {
    WG_REST_API
    AMNEZIA_API
}

enum ChargeStatus {
    PENDING
    COMPLETED
    FAILED
}
